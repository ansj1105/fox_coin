# ==========================================
# Foxya Coin Service - Environment Variables
# ==========================================
# 이 파일을 .env로 복사하여 실제 값을 입력하세요
# cp .env.example .env

# ==================== Application ====================
APP_ENV=prod
APP_VERSION=1.0.0

# ==================== OAuth (Google/Kakao) ====================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# GOOGLE_ANDROID_CLIENT_ID=
# GOOGLE_ANDROID_REDIRECT_URI=
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# KAKAO_REDIRECT_URI=
# KAKAO_ANDROID_REDIRECT_URI=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_SERVICE_ID=
# APPLE_IOS_CLIENT_ID=
# APPLE_PRIVATE_KEY_PATH=
# APPLE_REDIRECT_URI=
# APPLE_IOS_REDIRECT_URI=

# ==================== JVM Options ====================
JAVA_OPTS=-Xmx1024m -Xms512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ==================== Database ====================
# 앱은 항상 DB 프록시(VIP/HAProxy/Pgpool)로 접속하고,
# 백업/마이그레이션은 Primary 전용 경로(DB_ADMIN_*)를 사용하세요.
DB_HOST=db-proxy
DB_PORT=5432
DB_NAME=coin_system_cloud
DB_USER=foxya
# DB_PASSWORD=change-this-in-production
DB_POOL_SIZE=12
BACKGROUND_JOBS_ENABLED=true


# ==================== Active-Standby DB Routing ====================
# Fox Coin 권장 전략: PostgreSQL synchronous replication
# Primary/Standby 실제 주소. 현재 단일 DB만 있으면 둘 다 postgres로 두면 됩니다.
DB_PRIMARY_HOST=postgres
DB_PRIMARY_PORT=5432
DB_STANDBY_HOST=postgres
DB_STANDBY_PORT=5432

# app 서버 안의 db-proxy 바인딩 포트 (컨테이너 내부는 항상 5432)
DB_PROXY_PORT=5432
DB_PROXY_BIND_PORT=15432

# 백업/마이그레이션/점검용 Primary 직결 경로
DB_ADMIN_MODE=container
DB_ADMIN_SERVICE=postgres
DB_ADMIN_HOST=postgres
DB_ADMIN_PORT=5432

# ==================== Internal / Monitoring ====================
# 입금 스캐너(coin_publish)가 내부 API(/api/v1/internal/deposits/*) 호출 시 사용.
# coin_publish의 COIN_SERVICE_INTERNAL_API_KEY와 동일한 값 사용.
# 미설정 시 config.json의 depositScanner.apiKey 사용. 둘 다 없으면 내부 입금 API 401.
DEPOSIT_SCANNER_API_KEY=dsc_ddbeed7425219f5722ac06fdf59d88c0

# 모니터링 API 인증. 미설정 시 config.json의 monitoring.apiKey 사용.
# MONITORING_API_KEY=

# ==================== External HTTP Timeout ====================
# OAuth/지갑/Vision 등 외부 API 공통 WebClient 타임아웃
# EXTERNAL_HTTP_CONNECT_TIMEOUT_MS=5000
# EXTERNAL_HTTP_IDLE_TIMEOUT_SECONDS=15
# 환율 외부 API(CoinGecko/CoinPaprika) 실패 재처리(Redis Stream) 설정
# app_config 키(exchange_rate_retry_*)가 있으면 DB 값 우선, 없으면 아래 env/default 사용
# EXCHANGE_RATE_RETRY_MAX_RETRIES=6
# EXCHANGE_RATE_RETRY_PROCESSOR_MS=10000
# EXCHANGE_RATE_RETRY_BATCH=5
# EXCHANGE_RATE_RETRY_BLOCK_MS=1000
# EXCHANGE_RATE_RETRY_CONSUMER_GROUP=exchange-rate-retry-group
# EXCHANGE_RATE_RETRY_CONSUMER_NAME=api-1

# ==================== Profile Image Moderation ====================
# 서버 저장 경로 (컨테이너 내부 경로)
PROFILE_IMAGE_UPLOAD_DIR=/app/storage/profile-images
# true로 설정하면 Google Vision SafeSearch로 선정성/폭력성 이미지 업로드 차단
PROFILE_IMAGE_MODERATION_ENABLED=false
# Google Cloud Vision API 키 (미설정 시 moderation=true라도 검수 실패로 업로드 차단)
# GOOGLE_CLOUD_VISION_API_KEY=

# ==================== FCM (푸시 알림) ====================
# Firebase(https://console.firebase.google.com) 가입 후 프로젝트 생성 → 서비스 계정 키(JSON) 발급 필요.
# Firebase 서비스 계정 JSON 파일 절대 경로 (프로젝트 안이 아닌 로컬/서버 별도 경로 권장).
# 미설정 시 푸시 비활성(알림 DB만 저장). 해당 JSON은 Git에 커밋하지 말 것.
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/firebase-service-account.json
# FCM_CREDENTIALS_PATH=/var/secrets/firebase-service-account.json
# FCM_CREDENTIALS_HOST_PATH=/var/www/korion-wallet-69f0a-firebase-adminsdk-fbsvc-215386f23c.json
# (선택) 컨테이너 내부 경로를 명시적으로 오버라이드하려면 아래 사용
# FCM_CREDENTIALS_PATH=/var/secrets/firebase-service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/firebase-service-account.json
# FCM 실패 재처리(Redis Stream) 설정
# app_config 키(fcm_retry_*)가 있으면 DB 값 우선, 없으면 아래 env/default 사용
# FCM_RETRY_MAX_RETRIES=5
# FCM_RETRY_PROCESSOR_MS=5000
# FCM_RETRY_BATCH=20
# FCM_RETRY_BLOCK_MS=700
# FCM_RETRY_CONSUMER_GROUP=fcm-retry-group
# FCM_RETRY_CONSUMER_NAME=api-1

# ==================== Note ====================
# JWT, Redis 기본값은 config.json에서 관리합니다.
# Database는 config.json 기본값 위에 .env(DB_*)가 우선 적용됩니다.
