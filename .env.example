# ==========================================
# Foxya Coin Service - Environment Variables
# ==========================================
# 이 파일을 .env로 복사하여 실제 값을 입력하세요
# cp .env.example .env

# ==================== Application ====================
APP_ENV=prod
APP_VERSION=1.0.0

# ==================== OAuth (Google/Kakao) ====================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# GOOGLE_ANDROID_CLIENT_ID=
# GOOGLE_ANDROID_REDIRECT_URI=
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# KAKAO_REDIRECT_URI=
# KAKAO_ANDROID_REDIRECT_URI=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_SERVICE_ID=
# APPLE_IOS_CLIENT_ID=
# APPLE_PRIVATE_KEY_PATH=
# APPLE_REDIRECT_URI=
# APPLE_IOS_REDIRECT_URI=

# ==================== JVM Options ====================
JAVA_OPTS=-Xmx1024m -Xms512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ==================== Database ====================
# 앱 런타임은 PgBouncer의 고정 alias(foxya-runtime-db)로 접속하고,
# 백업/마이그레이션은 Primary 전용 경로(DB_ADMIN_*)를 사용하세요.
APP_DB_HOST=foxya-runtime-db
APP_DB_PORT=6432
DB_NAME=coin_system_cloud
DB_USER=foxya
# DB_PASSWORD=change-this-in-production
APP_DB_POOL_SIZE=12
APP_BACKGROUND_JOBS_ENABLED=true
APP2_DB_POOL_SIZE=8
APP2_BACKGROUND_JOBS_ENABLED=false
DB_ALERT_MONITOR_ENABLED=true
DB_ALERT_POLL_MS=15000
DB_ALERT_CONNECTION_RATIO_THRESHOLD=0.75
DB_ALERT_LOCK_WAIT_THRESHOLD=3
DB_ALERT_SYNC_REP_WAIT_THRESHOLD=1
DB_ALERT_CONSECUTIVE_BREACHES=2


# ==================== Active-Standby DB Routing ====================
# Fox Coin 권장 전략: PostgreSQL synchronous replication
# 현재 운영 추정값:
#   Primary private IP = 172.31.36.110 (52.200.97.155)
#   Standby private IP = 172.31.31.109 (52.204.57.80)
# primary 앱 서버는 local postgres:5432를 primary로 사용합니다.
DB_PRIMARY_HOST=postgres
DB_PRIMARY_PORT=5432
DB_STANDBY_HOST=172.31.31.109
# standby 호스트는 foxya-postgres-standby를 15432 -> 5432로 공개합니다.
DB_STANDBY_PORT=15432

# PostgreSQL synchronous replication 기본값
REPL_USER=replicator
# REPL_PASSWORD=change-this-replication-password
REPLICATION_SLOT=fox_coin_standby_1
SYNC_STANDBY_NAME=db_standby

# app 서버 안의 db-proxy 바인딩 포트 (컨테이너 내부는 항상 5432)
DB_PROXY_PORT=5432
DB_PROXY_BIND_ADDRESS=127.0.0.1
DB_PROXY_BIND_PORT=15432
# write path는 standby 자동 fallback을 기본 금지합니다.
DB_PROXY_STANDBY_FALLBACK_ENABLED=false

# 앱 컨테이너가 db-proxy 앞단의 PgBouncer로 접속할 때 사용하는 포트
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=400
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_MIN_POOL_SIZE=5
PGBOUNCER_RESERVE_POOL_SIZE=5
PGBOUNCER_RESERVE_POOL_TIMEOUT=5
PGBOUNCER_MAX_DB_CONNECTIONS=40
PGBOUNCER_QUERY_WAIT_TIMEOUT=120
PGBOUNCER_SERVER_CONNECT_TIMEOUT=5
PGBOUNCER_IDLE_TRANSACTION_TIMEOUT=60

# 백업/마이그레이션/점검용 Primary 직결 경로
DB_ADMIN_MODE=network
DB_ADMIN_SERVICE=postgres
DB_ADMIN_HOST=127.0.0.1
DB_ADMIN_PORT=5432

# ==================== Internal / Monitoring ====================
# 입금 스캐너(coin_publish)가 내부 API(/api/v1/internal/deposits/*) 호출 시 사용.
# coin_publish의 COIN_SERVICE_INTERNAL_API_KEY와 동일한 값 사용.
# 미설정 시 config.json의 depositScanner.apiKey 사용. 둘 다 없으면 내부 입금 API 401.
DEPOSIT_SCANNER_API_KEY=dsc_ddbeed7425219f5722ac06fdf59d88c0
# coin_manage -> foxya 출금 상태 callback 전용 내부 키. 비어 있으면 DEPOSIT_SCANNER_API_KEY fallback 사용.
KORION_WITHDRAW_CALLBACK_API_KEY=
# offline_pay 관리자/사용자 조회 프록시 및 snapshot notifier 대상 base URL
OFFLINE_PAY_BASE_URL=http://localhost
# offline_pay -> foxya 거래내역 기록 내부 키.
OFFLINE_PAY_INTERNAL_API_KEY=
# 신규 운영 기준에서는 legacy withdrawal stream/scheduler를 기본 비활성화합니다.
LEGACY_WITHDRAWAL_STREAM_ENABLED=false
LEGACY_WITHDRAWAL_REDISPATCH_ENABLED=false
LEGACY_WAITING_WITHDRAWAL_PROMOTION_ENABLED=false
# 신규 출금 요청을 coin_manage로 브리지할지 여부.
KORION_WITHDRAW_BRIDGE_ENABLED=false
KORION_WITHDRAW_API_URL=http://korion-service:3000
KORION_WITHDRAW_API_PATH=/api/withdrawals
KORION_WITHDRAW_API_KEY=
KORION_WITHDRAW_BRIDGE_CURRENCY_CODES=KORI,FOXYA
# legacy TRON virtual wallet owner binding/login 복구용 핫월렛 주소
# TRON_HOT_WALLET_ADDRESS=
# TRON worker signed ledger contract verification
LEDGER_EXPECTED_ISSUER=korion
# LEDGER_SHARED_HMAC_SECRET=<coin_manage 와 동일한 shared secret>

# 모니터링 API 인증. 미설정 시 config.json의 monitoring.apiKey 사용.
# MONITORING_API_KEY=
# DB 이상징후 텔레그램 알림. coin_manage와 같은 키 이름을 재사용합니다.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ==================== External HTTP Timeout ====================
# OAuth/지갑/Vision 등 외부 API 공통 WebClient 타임아웃
# EXTERNAL_HTTP_CONNECT_TIMEOUT_MS=5000
# EXTERNAL_HTTP_IDLE_TIMEOUT_SECONDS=15
# 환율 외부 API(CoinGecko/CoinPaprika) 실패 재처리(Redis Stream) 설정
# app_config 키(exchange_rate_retry_*)가 있으면 DB 값 우선, 없으면 아래 env/default 사용
# EXCHANGE_RATE_RETRY_MAX_RETRIES=6
# EXCHANGE_RATE_RETRY_PROCESSOR_MS=10000
# EXCHANGE_RATE_RETRY_BATCH=5
# EXCHANGE_RATE_RETRY_BLOCK_MS=1000
# EXCHANGE_RATE_RETRY_CONSUMER_GROUP=exchange-rate-retry-group
# EXCHANGE_RATE_RETRY_CONSUMER_NAME=api-1

# ==================== Profile Image Moderation ====================
# 서버 저장 경로 (컨테이너 내부 경로)
PROFILE_IMAGE_UPLOAD_DIR=/app/storage/profile-images
# true로 설정하면 Google Vision SafeSearch로 선정성/폭력성 이미지 업로드 차단
PROFILE_IMAGE_MODERATION_ENABLED=false
# Google Cloud Vision API 키 (미설정 시 moderation=true라도 검수 실패로 업로드 차단)
# GOOGLE_CLOUD_VISION_API_KEY=

# ==================== FCM (푸시 알림) ====================
# Firebase(https://console.firebase.google.com) 가입 후 프로젝트 생성 → 서비스 계정 키(JSON) 발급 필요.
# Firebase 서비스 계정 JSON 파일 절대 경로 (프로젝트 안이 아닌 로컬/서버 별도 경로 권장).
# 미설정 시 푸시 비활성(알림 DB만 저장). 해당 JSON은 Git에 커밋하지 말 것.
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/firebase-service-account.json
# FCM_CREDENTIALS_PATH=/var/secrets/firebase-service-account.json
# FCM_CREDENTIALS_HOST_PATH=/var/www/korion-wallet-69f0a-firebase-adminsdk-fbsvc-215386f23c.json
# (선택) 컨테이너 내부 경로를 명시적으로 오버라이드하려면 아래 사용
# FCM_CREDENTIALS_PATH=/var/secrets/firebase-service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/firebase-service-account.json
# FCM 실패 재처리(Redis Stream) 설정
# app_config 키(fcm_retry_*)가 있으면 DB 값 우선, 없으면 아래 env/default 사용
# FCM_RETRY_MAX_RETRIES=5
# FCM_RETRY_PROCESSOR_MS=5000
# FCM_RETRY_BATCH=20
# FCM_RETRY_BLOCK_MS=700
# FCM_RETRY_CONSUMER_GROUP=fcm-retry-group
# FCM_RETRY_CONSUMER_NAME=api-1

# ==================== Note ====================
# JWT, Redis 기본값은 config.json에서 관리합니다.
# Database는 config.json 기본값 위에 .env(DB_*)가 우선 적용됩니다.
