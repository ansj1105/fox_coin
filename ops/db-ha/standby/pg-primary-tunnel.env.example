CONTAINER_NAME=foxya-postgres-standby
LOCAL_BIND=127.0.0.1:15433
REMOTE_HOST=54.210.92.221
# main 서버 host localhost bind를 타도록 두면 postgres 컨테이너 IP가 바뀌어도 유지됩니다.
REMOTE_TARGET=127.0.0.1:5432
SSH_USER=ubuntu
SSH_KEY=/home/ubuntu/.ssh/pg_primary_tunnel
KNOWN_HOSTS=/home/ubuntu/.ssh/known_hosts
DOCKER_BIN=/usr/bin/docker
NSENTER_BIN=/usr/bin/nsenter
SSH_BIN=/usr/bin/ssh
POLL_INTERVAL=2
